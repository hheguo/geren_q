.modal-overlay {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0, 0, 0, 0.6);
  z-index: 9999;
  display: flex;
  align-items: center;
  justify-content: center;
  opacity: 0;
  pointer-events: none;
  transition: opacity 0.3s;
}

.modal-overlay.show {
  opacity: 1;
  pointer-events: auto;
}

.modal {
  width: 600rpx;
  background: #1e293b;
  border-radius: 32rpx;
  padding: 48rpx 40rpx;
  border: 1rpx solid rgba(148, 163, 184, 0.1);
  box-shadow: 0 20rpx 50rpx rgba(0, 0, 0, 0.3);
  transform: scale(0.95);
  transition: transform 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);
}

.modal-overlay.show .modal {
  transform: scale(1);
}

.modal-header {
  text-align: center;
  margin-bottom: 40rpx;
}

.modal-title {
  display: block;
  font-size: 36rpx;
  font-weight: 700;
  color: #f8fafc;
  margin-bottom: 12rpx;
}

.modal-subtitle {
  font-size: 26rpx;
  color: #94a3b8;
}

.form-content {
  display: flex;
  flex-direction: column;
  gap: 32rpx;
}

.btn-avatar {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  background: rgba(99, 102, 241, 0.1);
  border: 2rpx dashed rgba(99, 102, 241, 0.3);
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 0 auto;
  padding: 0;
  overflow: hidden;
}

.btn-avatar image {
  width: 100%;
  height: 100%;
}

.btn-avatar text {
  font-size: 24rpx;
  color: #818cf8;
}

.input-row {
  background: rgba(15, 23, 42, 0.4);
  border: 1rpx solid rgba(148, 163, 184, 0.1);
  border-radius: 16rpx;
  padding: 20rpx 24rpx;
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.label {
  font-size: 28rpx;
  color: #94a3b8;
}

.input {
  flex: 1;
  font-size: 28rpx;
  color: #f1f5f9;
  height: 40rpx;
}

.btn-primary {
  background: linear-gradient(135deg, #6366f1, #8b5cf6);
  color: #fff;
  border-radius: 20rpx;
  font-size: 30rpx;
  font-weight: 600;
  padding: 24rpx 0;
  width: 100%;
  text-align: center;
  margin-top: 16rpx;
}

.btn-primary.disabled {
  opacity: 0.6;
}

.btn-cancel {
  text-align: center;
  font-size: 26rpx;
  color: #64748b;
  padding: 10rpx;
}
