.container {
  padding: 24rpx 32rpx;
  min-height: 100vh;
}

/* 空状态 */
.empty-state {
  text-align: center;
  padding: 80rpx 40rpx;
}

.empty-icon {
  display: block;
  font-size: 80rpx;
  margin-bottom: 20rpx;
  opacity: 0.5;
}

.empty-text {
  font-size: 28rpx;
  color: #64748b;
  line-height: 1.6;
}

/* 历史列表 */
.history-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.history-item {
  padding: 24rpx 28rpx;
  background: rgba(30, 41, 59, 0.65);
  border: 1rpx solid rgba(148, 163, 184, 0.12);
  border-radius: 20rpx;
  animation: slideIn 0.4s cubic-bezier(0.4, 0, 0.2, 1) both;
}

@keyframes slideIn {
  from {
    opacity: 0;
    transform: translateX(-20rpx);
  }
  to {
    opacity: 1;
    transform: translateX(0);
  }
}

.history-round {
  display: block;
  font-size: 24rpx;
  font-weight: 600;
  color: #818cf8;
  margin-bottom: 12rpx;
}

.history-scores {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.score-chip {
  display: inline-flex;
  align-items: center;
  padding: 6rpx 16rpx;
  font-size: 24rpx;
  font-weight: 500;
  border-radius: 10rpx;
}

.score-chip.positive {
  background: rgba(16, 185, 129, 0.15);
  color: #10b981;
}

.score-chip.negative {
  background: rgba(239, 68, 68, 0.15);
  color: #ef4444;
}

.score-chip.zero {
  background: rgba(100, 116, 139, 0.15);
  color: #64748b;
}
