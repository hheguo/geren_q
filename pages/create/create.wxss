.container {
  padding: 24rpx 32rpx;
  min-height: 100vh;
}

/* 按钮禁用态 */
.btn-disabled {
  opacity: 0.6;
  pointer-events: none;
}

.switch-group {
  flex-direction: row;
  justify-content: space-between;
  align-items: center;
}

/* ---------- 加载遮罩 ---------- */
.loading-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.55);
  z-index: 999;
  display: flex;
  align-items: center;
  justify-content: center;
}

.loading-content {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 24rpx;
}

.input-field {
  width: 100%;
  height: 88rpx;
  background: #2D2D2D;
  border-radius: 12rpx;
  padding: 0 24rpx;
  color: #fff;
  font-size: 30rpx;
}

.loading-spinner {
  width: 64rpx;
  height: 64rpx;
  border: 5rpx solid rgba(255, 255, 255, 0.15);
  border-top: 5rpx solid #818cf8;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.loading-text {
  font-size: 28rpx;
  color: #e2e8f0;
  font-weight: 500;
}
