<view class="page-enter">
  <view class="container">
    <view class="card">
      <view class="card-title">🎲 创建新房间</view>

      <!-- 昵称 -->
      <view class="input-group">
        <text class="input-label">你的昵称</text>
        <input class="input-field" value="{{nickname}}" bindinput="onNicknameInput"
               placeholder="请输入昵称" placeholder-class="placeholder-cls" maxlength="12" />
      </view>

      <!-- 底分 -->
      <view class="input-group">
        <text class="input-label">底分</text>
        <input class="input-field" type="number" bindinput="onBaseScoreInput"
               placeholder="默认 1" placeholder-class="placeholder-cls" />
      </view>

      <!-- 台版开关 -->
      <view class="input-group switch-group">
        <text class="input-label">台版模式</text>
        <switch checked="{{isTaiban}}" bindchange="onTaibanChange" color="#6366f1" />
      </view>



      <!-- 创建按钮 -->
      <button class="btn btn-primary {{loading ? 'btn-disabled' : ''}}" bindtap="doCreate" style="margin-top: 16rpx;">
        {{loading ? '创建中…' : '创建房间'}}
      </button>
    </view>
  </view>

  <auth-modal show="{{showLogin}}" bind:success="onLoginSuccess" bind:cancel="onLoginCancel" />
  
  <!-- 加载遮罩 -->
  <view class="loading-overlay" wx:if="{{loading}}">
    <view class="loading-content">
      <view class="loading-spinner"></view>
      <text class="loading-text">正在创建房间…</text>
    </view>
  </view>
</view>
