.container {
  min-height: 100vh;
  padding: 32rpx;
  background: #0f172a;
  color: #f8fafc;
}

.container.light {
  background: #f8fafc;
  color: #0f172a;
}

.header {
  margin-bottom: 32rpx;
  padding-bottom: 24rpx;
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.1);
}

.container.light .header {
  border-bottom: 1rpx solid #e2e8f0;
  color: #1e293b;
}

.title {
  font-size: 32rpx;
  font-weight: 700;
}

/* History Item Styles (Copied from profile.wxss) */
.history-item {
  padding: 24rpx;
  background: rgba(30, 41, 59, 0.5);
  border: 1rpx solid rgba(148, 163, 184, 0.08);
  border-radius: 16rpx;
  margin-bottom: 16rpx;
  animation: slideIn 0.35s ease both;
}

.container.light .history-item {
  background: #fff;
  border: 1rpx solid #e2e8f0;
  box-shadow: 0 2rpx 10rpx rgba(0,0,0,0.05);
}

@keyframes slideIn {
  from { opacity: 0; transform: translateY(16rpx); }
  to { opacity: 1; transform: translateY(0); }
}

.hi-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}

.hi-code {
  font-size: 28rpx;
  font-weight: 600;
  color: #818cf8;
}

.hi-time {
  font-size: 22rpx;
  color: #94a3b8;
}

.hi-players {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-bottom: 8rpx;
}

.hi-player {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 4rpx 16rpx;
  background: rgba(99, 102, 241, 0.06);
  border-radius: 8rpx;
  font-size: 24rpx;
}

.hp-name {
  color: #f1f5f9;
}

.container.light .hp-name {
  color: #334155;
}

.hp-score {
  font-weight: 600;
}

.text-positive { color: #f43f5e; }
.text-negative { color: #10b981; }
.text-zero { color: #94a3b8; }

.hi-rounds {
  font-size: 22rpx;
  color: #64748b;
}

.empty-state {
  text-align: center;
  padding: 60rpx 40rpx;
}

.empty-icon {
  display: block;
  font-size: 72rpx;
  margin-bottom: 16rpx;
  opacity: 0.5;
}

.empty-text {
  font-size: 28rpx;
  color: #64748b;
}
