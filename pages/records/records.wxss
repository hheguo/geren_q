.page-container {
  min-height: 100vh;
  background-color: #0a0e1a;
  color: #e2e8f0;
  display: flex;
  flex-direction: column;
}

.tabs {
  display: flex;
  background-color: #111827;
  padding: 0 32rpx;
  border-bottom: 1rpx solid #1f2937;
  position: sticky;
  top: 0;
  z-index: 10;
}

.tab-item {
  flex: 1;
  text-align: center;
  padding: 32rpx 0;
  font-size: 30rpx;
  color: #94a3b8;
  position: relative;
}

.tab-item.active {
  color: #fff;
  font-weight: 600;
}

.tab-line {
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 48rpx;
  height: 6rpx;
  background-color: #818cf8;
  border-radius: 6rpx;
}

.content {
  flex: 1;
  padding: 24rpx;
}

.room-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.room-card {
  background-color: #1f2937;
  border-radius: 16rpx;
  padding: 24rpx;
  border: 1rpx solid #374151;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.card-ended {
  opacity: 0.7;
}

.card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.room-code {
  font-size: 32rpx;
  font-weight: 600;
  color: #fff;
}

.tag-live {
  font-size: 24rpx;
  color: #4ade80;
  background-color: rgba(74, 222, 128, 0.1);
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
}

.tag-ended {
  font-size: 24rpx;
  color: #94a3b8;
  background-color: rgba(148, 163, 184, 0.1);
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
}

.card-body {
  display: flex;
  justify-content: space-between;
  font-size: 26rpx;
  color: #94a3b8;
}

.card-footer {
  border-top: 1rpx solid #374151;
  padding-top: 16rpx;
  text-align: right;
}

.btn-text {
  font-size: 26rpx;
  color: #818cf8;
}

.empty-state {
  margin-top: 100rpx;
  text-align: center;
  color: #64748b;
  font-size: 28rpx;
}
