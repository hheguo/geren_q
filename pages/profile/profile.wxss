.container {
  position: relative;
  z-index: 1;
  padding: 32rpx;
  min-height: 100vh;
}

/* 按钮禁用透明度 */
.btn-disabled {
  opacity: 0.6;
  pointer-events: none;
}

/* ---------- 用户卡片 ---------- */
.user-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 48rpx 40rpx;
  text-align: center;
}

.avatar-placeholder {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #6366f1, #8b5cf6);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 20rpx;
}

.ap-icon {
  font-size: 56rpx;
  line-height: 120rpx;
}

.user-avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  margin-bottom: 20rpx;
  border: 3rpx solid rgba(99, 102, 241, 0.3);
}

.user-name {
  font-size: 36rpx;
  font-weight: 700;
  margin-bottom: 8rpx;
}

.login-hint {
  font-size: 28rpx;
  color: #94a3b8;
  margin: 12rpx 0 24rpx;
}

.btn-avatar {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  padding: 24rpx 40rpx;
  border: none;
  border-radius: 20rpx;
  font-size: 28rpx;
  font-weight: 600;
  background: rgba(99, 102, 241, 0.12);
  color: #818cf8;
  line-height: 1.4;
}

.btn-avatar::after {
  border: none;
}

/* ---------- 主题切换 ---------- */
.theme-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.theme-label {
  font-size: 28rpx;
  color: #94a3b8;
}

.switch-track {
  width: 100rpx;
  height: 52rpx;
  border-radius: 30rpx;
  background: rgba(99, 102, 241, 0.2);
  position: relative;
  transition: background 0.3s;
}

.switch-light {
  background: rgba(245, 158, 11, 0.25);
}

.switch-thumb {
  position: absolute;
  top: 4rpx;
  left: 4rpx;
  width: 44rpx;
  height: 44rpx;
  border-radius: 50%;
  background: #1e293b;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  transition: left 0.3s, background 0.3s;
  line-height: 44rpx;
  text-align: center;
}

.thumb-right {
  left: 52rpx;
  background: #fef3c7;
}

/* ---------- 浅色主题 ---------- */
.theme-light {
  color: #1e293b;
}

.theme-light .card {
  background: rgba(255, 255, 255, 0.9);
  border-color: rgba(0, 0, 0, 0.08);
}

.theme-light .card-title {
  color: #1e293b;
}

.theme-light .input-field {
  background: rgba(241, 245, 249, 0.8);
  border-color: rgba(0, 0, 0, 0.1);
  color: #1e293b !important;
}

.theme-light .theme-label {
  color: #475569;
}

/* ---------- 空状态 ---------- */
.empty-state {
  text-align: center;
  padding: 60rpx 40rpx;
}

.empty-icon {
  display: block;
  font-size: 72rpx;
  margin-bottom: 16rpx;
  opacity: 0.5;
}

.empty-text {
  font-size: 28rpx;
  color: #64748b;
}

/* ---------- 历史房间列表 ---------- */
.history-item {
  padding: 24rpx;
  background: rgba(30, 41, 59, 0.5);
  border: 1rpx solid rgba(148, 163, 184, 0.08);
  border-radius: 16rpx;
  margin-bottom: 16rpx;
  animation: slideIn 0.35s ease both;
}

@keyframes slideIn {
  from { opacity: 0; transform: translateY(16rpx); }
  to { opacity: 1; transform: translateY(0); }
}

.hi-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}

.hi-code {
  font-size: 28rpx;
  font-weight: 600;
  color: #818cf8;
}

.hi-time {
  font-size: 22rpx;
}

.hi-players {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-bottom: 8rpx;
}

.hi-player {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 4rpx 16rpx;
  background: rgba(99, 102, 241, 0.06);
  border-radius: 8rpx;
  font-size: 24rpx;
}

.hp-name {
  color: #f1f5f9;
}

.hp-score {
  font-weight: 600;
}

.hi-rounds {
  font-size: 22rpx;
}

/* ---------- 反馈 ---------- */
.feedback-types {
  display: flex;
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.fb-type {
  flex: 1;
  text-align: center;
  padding: 16rpx 0;
  font-size: 26rpx;
  background: rgba(30, 41, 59, 0.5);
  border: 1rpx solid rgba(148, 163, 184, 0.12);
  border-radius: 12rpx;
  color: #94a3b8;
}

.fb-type-active {
  border-color: #6366f1;
  background: rgba(99, 102, 241, 0.12);
  color: #818cf8;
}

.feedback-textarea {
  width: 100%;
  min-height: 160rpx;
  padding: 24rpx;
  font-size: 28rpx;
  line-height: 1.6;
  box-sizing: border-box;
}

/* ---------- 菜单列表 ---------- */
.menu-card {
  padding: 0 !important;
  overflow: hidden;
}

.menu-list {
  width: 100%;
}

.menu-item {
  display: flex;
  align-items: center;
  padding: 32rpx 40rpx;
  position: relative;
}

.menu-item:active {
  background: rgba(255, 255, 255, 0.05);
}

.theme-light .menu-item:active {
  background: rgba(0, 0, 0, 0.03);
}

.menu-icon {
  width: 64rpx;
  height: 64rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 24rpx;
  background: rgba(99, 102, 241, 0.1);
}

.menu-icon .iconfont {
  font-size: 32rpx;
}

.menu-text {
  flex: 1;
  font-size: 30rpx;
  color: #f1f5f9;
  font-weight: 500;
}

.theme-light .menu-text {
  color: #334155;
}

.menu-arrow {
  font-size: 28rpx;
  color: #94a3b8;
  font-family: monospace;
}
