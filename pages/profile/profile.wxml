<view class="page-enter {{theme === 'light' ? 'theme-light' : ''}}">
  <view class="bg-orb bg-orb-1"></view>
  <view class="bg-orb bg-orb-2"></view>

  <view class="container">

    <!-- 未登录 -->
    <view class="card user-card" wx:if="{{!isLoggedIn}}">
      <view class="avatar-placeholder">
        <text class="ap-icon">👤</text>
      </view>
      <text class="login-hint">登录后可查看历史记录</text>

      <button class="btn btn-avatar" open-type="chooseAvatar" bindchooseavatar="onChooseAvatar">
        选择微信头像
      </button>

      <view class="input-group" style="margin-top: 24rpx; width: 100%;">
        <text class="input-label">昵称</text>
        <input class="input-field" type="nickname" value="{{tempNickname}}"
               bindinput="onNicknameInput" placeholder="点击获取微信昵称"
               placeholder-class="placeholder-cls" />
      </view>

      <button class="btn btn-primary {{loading ? 'btn-disabled' : ''}}" bindtap="doLogin" style="margin-top: 24rpx;">
        {{loading ? '登录中…' : '确认登录'}}
      </button>
    </view>

    <!-- 已登录 -->
    <view class="card user-card" wx:else>
      <image class="user-avatar" src="{{avatarUrl}}" mode="aspectFill" wx:if="{{avatarUrl}}" />
      <view class="avatar-placeholder" wx:else>
        <text class="ap-icon">{{nickname[0] || '我'}}</text>
      </view>
      <text class="user-name">{{nickname}}</text>
    </view>

    <!-- 菜单列表 -->
    <view class="card menu-card">
      <view class="menu-list">
        <view class="menu-item" bindtap="goBill">
          <view class="menu-icon bill-icon">
            <text class="iconfont">📜</text>
          </view>
          <text class="menu-text">个人历史汇总</text>
          <text class="menu-arrow">></text>
        </view>
        <!-- 清除缓存 -->
        <view class="menu-item" bindtap="clearCache">
          <view class="menu-icon bill-icon">
            <text class="iconfont">🗑️</text>
          </view>
          <text class="menu-text">清除缓存</text>
          <text class="menu-arrow">></text>
        </view>
      </view>
    </view>

    <!-- ======= 主题切换 (暂藏) ======= -->
    <!-- 
    <view class="card">
      <view class="card-title">🎨 主题设置</view>
      <view class="theme-row">
        <text class="theme-label">当前: {{theme === 'dark' ? '深色' : '浅色'}}</text>
        <view class="theme-switch" bindtap="toggleTheme">
          <view class="switch-track {{theme === 'light' ? 'switch-light' : ''}}">
            <view class="switch-thumb {{theme === 'light' ? 'thumb-right' : ''}}">
              {{theme === 'dark' ? '🌙' : '☀️'}}
            </view>
          </view>
        </view>
      </view>
    </view> 
    -->



    <!-- ======= 反馈 ======= -->
    <view class="card">
      <view class="card-title">💬 意见反馈</view>

      <!-- 反馈类型 -->
      <view class="feedback-types">
        <view class="fb-type {{feedbackType === 'bug' ? 'fb-type-active' : ''}}" bindtap="setFbType" data-type="bug">🐛 Bug</view>
        <view class="fb-type {{feedbackType === 'suggestion' ? 'fb-type-active' : ''}}" bindtap="setFbType" data-type="suggestion">💡 建议</view>
        <view class="fb-type {{feedbackType === 'other' ? 'fb-type-active' : ''}}" bindtap="setFbType" data-type="other">📝 其他</view>
      </view>

      <view class="input-group">
        <textarea class="input-field feedback-textarea" value="{{feedbackContent}}"
                  bindinput="onFeedbackInput" placeholder="请描述你的问题或建议…"
                  placeholder-class="placeholder-cls" maxlength="500" />
      </view>

      <view class="input-group">
        <text class="input-label">联系方式（选填）</text>
        <input class="input-field" value="{{feedbackContact}}" bindinput="onContactInput"
               placeholder="微信号 / 手机号" placeholder-class="placeholder-cls" />
      </view>

      <button class="btn btn-primary {{loading ? 'btn-disabled' : ''}}" bindtap="submitFeedback">
        {{loading ? '提交中…' : '提交反馈'}}
      </button>
    </view>

    <!-- 退出登录 -->
    <button class="btn btn-sm btn-danger" wx:if="{{isLoggedIn}}" bindtap="doLogout"
            style="margin-top: 20rpx; margin-bottom: 40rpx;">
      退出登录
    </button>
  </view>
</view>
