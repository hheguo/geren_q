/* ==============================
   TenpAI 全局样式 - 深色毛玻璃主题
   ============================== */

page {
  background: #0a0e1a;
  color: #f1f5f9;
  font-family: -apple-system, BlinkMacSystemFont, 'Helvetica Neue', 'PingFang SC', sans-serif;
  font-size: 28rpx;
  min-height: 100vh;
}

/* ---------- 通用组件 ---------- */
.card {
  background: rgba(30, 41, 59, 0.65);
  border: 1rpx solid rgba(148, 163, 184, 0.12);
  border-radius: 28rpx;
  padding: 40rpx;
  margin-bottom: 24rpx;
}

.card-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #f1f5f9;
  margin-bottom: 28rpx;
}

/* 按钮 */
.btn {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  padding: 28rpx 40rpx;
  border: none;
  border-radius: 20rpx;
  font-size: 30rpx;
  font-weight: 600;
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  line-height: 1.4;
}

.btn::after {
  border: none;
}

.btn-primary {
  background: linear-gradient(135deg, #6366f1, #8b5cf6);
  color: #ffffff;
  box-shadow: 0 0 40rpx rgba(99, 102, 241, 0.25);
}

.btn-primary:active {
  transform: scale(0.97);
  opacity: 0.9;
}

.btn-secondary {
  background: rgba(30, 41, 59, 0.65);
  color: #f1f5f9;
  border: 1rpx solid rgba(148, 163, 184, 0.12);
}

.btn-secondary:active {
  background: rgba(30, 41, 59, 0.85);
  border-color: #6366f1;
}

.btn-danger {
  background: rgba(239, 68, 68, 0.15);
  color: #ef4444;
  border: 1rpx solid rgba(239, 68, 68, 0.2);
}

.btn-danger:active {
  background: rgba(239, 68, 68, 0.25);
}

.btn-sm {
  padding: 18rpx 32rpx;
  font-size: 26rpx;
  border-radius: 14rpx;
}

.btn-icon {
  margin-right: 12rpx;
  font-size: 32rpx;
}

.btn-group {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

/* 输入框 */
.input-group {
  margin-bottom: 32rpx;
}

.input-label {
  display: block;
  font-size: 24rpx;
  font-weight: 500;
  color: #94a3b8;
  margin-bottom: 12rpx;
  letter-spacing: 1rpx;
}

.input-field {
  width: 100%;
  padding: 24rpx 32rpx;
  background: rgba(15, 23, 42, 0.6);
  border: 1rpx solid rgba(148, 163, 184, 0.15);
  border-radius: 20rpx;
  color: #f1f5f9 !important;
  font-size: 30rpx;
  box-sizing: border-box;
  min-height: 80rpx;
}

/* 微信小程序 input placeholder 样式 */
.placeholder-cls {
  color: #64748b;
  font-size: 28rpx;
}

.input-field-focus {
  border-color: rgba(99, 102, 241, 0.5) !important;
  box-shadow: 0 0 0 4rpx rgba(99, 102, 241, 0.25);
}

/* 过渡动画 */
.page-enter {
  animation: pageEnter 0.45s cubic-bezier(0.4, 0, 0.2, 1) both;
}

@keyframes pageEnter {
  from {
    opacity: 0;
    transform: translateY(40rpx) scale(0.97);
  }
  to {
    opacity: 1;
    transform: translateY(0) scale(1);
  }
}

/* 背景光球 */
.bg-orb {
  position: fixed;
  border-radius: 50%;
  pointer-events: none;
  z-index: 0;
}

.bg-orb-1 {
  width: 500rpx;
  height: 500rpx;
  background: radial-gradient(circle, rgba(99, 102, 241, 0.1), transparent 70%);
  top: -150rpx;
  right: -150rpx;
  animation: floatOrb 20s ease-in-out infinite;
}

.bg-orb-2 {
  width: 450rpx;
  height: 450rpx;
  background: radial-gradient(circle, rgba(139, 92, 246, 0.08), transparent 70%);
  bottom: -120rpx;
  left: -120rpx;
  animation: floatOrb 20s ease-in-out infinite 10s;
}

@keyframes floatOrb {
  0%, 100% { transform: translate(0, 0) scale(1); }
  33% { transform: translate(40rpx, -40rpx) scale(1.05); }
  66% { transform: translate(-30rpx, 30rpx) scale(0.95); }
}

/* 分割线 */
.divider {
  display: flex;
  align-items: center;
  margin: 40rpx 0;
  color: #64748b;
  font-size: 24rpx;
  letter-spacing: 2rpx;
}

.divider::before,
.divider::after {
  content: '';
  flex: 1;
  height: 1rpx;
  background: rgba(148, 163, 184, 0.12);
}

.divider::before {
  margin-right: 24rpx;
}

.divider::after {
  margin-left: 24rpx;
}

/* 状态徽章 */
.status-badge {
  display: inline-flex;
  align-items: center;
  padding: 6rpx 20rpx;
  font-size: 22rpx;
  font-weight: 600;
  border-radius: 30rpx;
  letter-spacing: 1rpx;
}

.status-active {
  background: rgba(16, 185, 129, 0.12);
  color: #10b981;
}

.status-ended {
  background: rgba(100, 116, 139, 0.15);
  color: #64748b;
}

/* 颜色工具类 */
.text-positive { color: #10b981; }
.text-negative { color: #ef4444; }
.text-zero { color: #64748b; }
.text-muted { color: #64748b; }
.text-secondary { color: #94a3b8; }
